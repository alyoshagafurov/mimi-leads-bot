# Copy this file to .env and fill in the values.
# .env is git-ignored and must never contain a real token in version control.

# Token from @BotFather (required)
TELEGRAM_BOT_TOKEN=

# Local SQLite database file (bot is self-contained by default)
DATABASE_PATH=bot_leads.db

# Optional: read leads from mimi-leads-api instead of the local DB.
API_ENABLED=false
API_BASE_URL=http://localhost:8000

LOG_LEVEL=INFO
